<resources>
    <style name="Tile">
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="KeyboardButton">
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:background">@drawable/key_normal</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="KeyboardButtonSpecial" parent="KeyboardButton">
        <item name="android:background">@drawable/key_enter</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
